{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "checkJs": false
  },
  "watchOptions": {
    "fallbackPolling": "dynamicPriority"
  },
  "typeAcquisition": {
    "enable": false
  },
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build",
    "coverage",
    "tmp",
    "temp",
    ".git"
  ]
}
